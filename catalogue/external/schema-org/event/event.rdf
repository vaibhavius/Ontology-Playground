<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="https://schema.org/event-subset/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="https://schema.org/event-subset/">

    <owl:Ontology rdf:about="https://schema.org/event-subset/">
        <rdfs:label>Schema.org — Event</rdfs:label>
        <rdfs:comment>Events, venues, performers, and offers — a subset of Schema.org's vocabulary for describing events, ticket sales, and scheduling.</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="https://schema.org/event-subset/Event">
        <rdfs:label>Event</rdfs:label>
        <rdfs:comment>A happening at a specific time and place — concert, conference, sports match, etc.</rdfs:comment>
        <ont:icon>🎫</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://schema.org/event-subset/Place">
        <rdfs:label>Place</rdfs:label>
        <rdfs:comment>A venue or location where an event takes place</rdfs:comment>
        <ont:icon>📍</ont:icon>
        <ont:color>#E74C3C</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://schema.org/event-subset/Person">
        <rdfs:label>Person</rdfs:label>
        <rdfs:comment>A performer, organizer, or attendee of an event</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://schema.org/event-subset/Organization">
        <rdfs:label>Organization</rdfs:label>
        <rdfs:comment>A company or group that sponsors or organizes events</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://schema.org/event-subset/Offer">
        <rdfs:label>Offer</rdfs:label>
        <rdfs:comment>A ticket or admission offer with price and availability</rdfs:comment>
        <ont:icon>🎟️</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <!-- ===================== -->
    <!-- Properties            -->
    <!-- ===================== -->

    <owl:DatatypeProperty rdf:about="https://schema.org/event-subset/eventName">
        <rdfs:label>eventName</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/event-subset/startDate">
        <rdfs:label>startDate</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#datetime"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/event-subset/endDate">
        <rdfs:label>endDate</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#datetime"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/event-subset/placeName">
        <rdfs:label>placeName</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Place"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/event-subset/address">
        <rdfs:label>address</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Place"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/event-subset/maximumCapacity">
        <rdfs:label>maximumCapacity</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Place"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/event-subset/personName">
        <rdfs:label>personName</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/event-subset/email">
        <rdfs:label>email</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/event-subset/orgName">
        <rdfs:label>orgName</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Organization"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/event-subset/url">
        <rdfs:label>url</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Organization"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/event-subset/price">
        <rdfs:label>price</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Offer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/event-subset/availability">
        <rdfs:label>availability</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Offer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- ===================== -->
    <!-- Relationships         -->
    <!-- ===================== -->

    <owl:ObjectProperty rdf:about="https://schema.org/event-subset/location">
        <rdfs:label>location</rdfs:label>
        <rdfs:comment>The venue where the event takes place</rdfs:comment>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Event"/>
        <rdfs:range rdf:resource="https://schema.org/event-subset/Place"/>
        <ont:cardinality>many-to-one</ont:cardinality>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://schema.org/event-subset/performer">
        <rdfs:label>performer</rdfs:label>
        <rdfs:comment>A person performing at the event</rdfs:comment>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Event"/>
        <rdfs:range rdf:resource="https://schema.org/event-subset/Person"/>
        <ont:cardinality>many-to-many</ont:cardinality>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://schema.org/event-subset/organizer">
        <rdfs:label>organizer</rdfs:label>
        <rdfs:comment>The organization that hosts or sponsors the event</rdfs:comment>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Event"/>
        <rdfs:range rdf:resource="https://schema.org/event-subset/Organization"/>
        <ont:cardinality>many-to-one</ont:cardinality>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://schema.org/event-subset/offers">
        <rdfs:label>offers</rdfs:label>
        <rdfs:comment>Ticket or admission offers available for the event</rdfs:comment>
        <rdfs:domain rdf:resource="https://schema.org/event-subset/Event"/>
        <rdfs:range rdf:resource="https://schema.org/event-subset/Offer"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>

</rdf:RDF>
