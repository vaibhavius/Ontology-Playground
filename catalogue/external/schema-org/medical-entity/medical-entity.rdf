<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="https://schema.org/medical-entity-subset/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="https://schema.org/medical-entity-subset/">

    <owl:Ontology rdf:about="https://schema.org/medical-entity-subset/">
        <rdfs:label>Schema.org — MedicalEntity</rdfs:label>
        <rdfs:comment>Medical conditions, drugs, procedures, and healthcare providers — a health-domain subset of Schema.org.</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="https://schema.org/medical-entity-subset/MedicalCondition">
        <rdfs:label>MedicalCondition</rdfs:label>
        <rdfs:comment>A disease, disorder, or medical condition</rdfs:comment>
        <ont:icon>🩺</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://schema.org/medical-entity-subset/Drug">
        <rdfs:label>Drug</rdfs:label>
        <rdfs:comment>A pharmaceutical drug used to treat or manage a condition</rdfs:comment>
        <ont:icon>💊</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://schema.org/medical-entity-subset/MedicalProcedure">
        <rdfs:label>MedicalProcedure</rdfs:label>
        <rdfs:comment>A medical test, surgery, or therapeutic procedure</rdfs:comment>
        <ont:icon>🏥</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://schema.org/medical-entity-subset/Hospital">
        <rdfs:label>Hospital</rdfs:label>
        <rdfs:comment>A hospital or healthcare facility</rdfs:comment>
        <ont:icon>🏨</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="https://schema.org/medical-entity-subset/Physician">
        <rdfs:label>Physician</rdfs:label>
        <rdfs:comment>A medical doctor or specialist</rdfs:comment>
        <ont:icon>👨‍⚕️</ont:icon>
        <ont:color>#E74C3C</ont:color>
    </owl:Class>

    <!-- ===================== -->
    <!-- Properties            -->
    <!-- ===================== -->

    <owl:DatatypeProperty rdf:about="https://schema.org/medical-entity-subset/conditionName">
        <rdfs:label>conditionName</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/MedicalCondition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/medical-entity-subset/icdCode">
        <rdfs:label>icdCode</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/MedicalCondition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/medical-entity-subset/riskFactor">
        <rdfs:label>riskFactor</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/MedicalCondition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/medical-entity-subset/drugName">
        <rdfs:label>drugName</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/Drug"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/medical-entity-subset/dosageForm">
        <rdfs:label>dosageForm</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/Drug"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/medical-entity-subset/activeIngredient">
        <rdfs:label>activeIngredient</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/Drug"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/medical-entity-subset/procedureName">
        <rdfs:label>procedureName</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/MedicalProcedure"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/medical-entity-subset/procedureType">
        <rdfs:label>procedureType</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/MedicalProcedure"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/medical-entity-subset/hospitalName">
        <rdfs:label>hospitalName</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/Hospital"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/medical-entity-subset/bedCount">
        <rdfs:label>bedCount</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/Hospital"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/medical-entity-subset/physicianName">
        <rdfs:label>physicianName</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/Physician"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier>true</ont:isIdentifier>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://schema.org/medical-entity-subset/specialty">
        <rdfs:label>specialty</rdfs:label>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/Physician"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- ===================== -->
    <!-- Relationships         -->
    <!-- ===================== -->

    <owl:ObjectProperty rdf:about="https://schema.org/medical-entity-subset/possibleTreatment">
        <rdfs:label>possibleTreatment</rdfs:label>
        <rdfs:comment>A drug that may treat or manage this condition</rdfs:comment>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/MedicalCondition"/>
        <rdfs:range rdf:resource="https://schema.org/medical-entity-subset/Drug"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://schema.org/medical-entity-subset/diagnosticTest">
        <rdfs:label>diagnosticTest</rdfs:label>
        <rdfs:comment>A procedure used to diagnose this condition</rdfs:comment>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/MedicalCondition"/>
        <rdfs:range rdf:resource="https://schema.org/medical-entity-subset/MedicalProcedure"/>
        <ont:cardinality>one-to-many</ont:cardinality>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://schema.org/medical-entity-subset/availableAt">
        <rdfs:label>availableAt</rdfs:label>
        <rdfs:comment>A hospital where this procedure is performed</rdfs:comment>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/MedicalProcedure"/>
        <rdfs:range rdf:resource="https://schema.org/medical-entity-subset/Hospital"/>
        <ont:cardinality>many-to-many</ont:cardinality>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://schema.org/medical-entity-subset/affiliatedWith">
        <rdfs:label>affiliatedWith</rdfs:label>
        <rdfs:comment>The hospital a physician is affiliated with</rdfs:comment>
        <rdfs:domain rdf:resource="https://schema.org/medical-entity-subset/Physician"/>
        <rdfs:range rdf:resource="https://schema.org/medical-entity-subset/Hospital"/>
        <ont:cardinality>many-to-one</ont:cardinality>
    </owl:ObjectProperty>

</rdf:RDF>
